module _src;

import cloth.io.IO::{ println };
import cloth.lang.*;

public class (): Object -> Serializable, Nullable {

    public Test {
        void frag = run();
        frag();

        let x;// = 1;

        if (true) {
            println("Hello World");
        } else {
            println("I am Cloth!");
        }
    }

    public ~Test () {
        println("Goodbye World");
    }

    public Test(string s) {
    }

    public fragment run (): void {
        println("Hello World");
    }

    public fragment run (): void {
        println(" I am Cloth!");
    }

}