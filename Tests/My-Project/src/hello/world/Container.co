module hello.world;

import cloth.io.Out::{ println };

public class Container () {

    private i32 outerField = 42;
    private Inner child;

    public Container {
        this.child = new Inner();   // auto-captures `this`
    }

    public ~Container {}

    public func get(): i32 {
        return child.read();
    }

    public inner class Inner () {
        private i32 v = 7;
        public Inner {}
        public ~Inner {}
        public func read(): i32 {
            // `Container.this.outerField` is the explicit form of the same access.
            return v + Container.this.outerField;
        }
    }
}
