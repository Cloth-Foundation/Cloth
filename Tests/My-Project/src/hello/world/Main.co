module hello.world;

import cloth.io.Out::{ println as p };
import hello.foo.Foo;

public class (string[] args) {

    private PrintName printName;
    // TODO: re-enable once primitive nullable storage + println(any)/::STRING lands
    // private int? nullX = null;

    public Main {
        // nullX = 42;
        // p(nullX);

        sayHello();
        makeContainer();
        makeMulti();
        interfaceDispatch();
        defaultImpl();
        loopTests();
        nullTests();
        castTests();
        inheritanceTests();
    }

    public ~Main() {
    }

    public func sayHello() {
        printName = new PrintName("Cloth!");
        printName.print();
        delete printName;
    }

    public func makeContainer() {
        let c = new Container();
        p(c.get());                                 // 7 + 42 = 49 (inner constructed in ctor)
        let i = c.new Container.Inner();
        p(i.read());                            // 7 + 42 = 49 (constructed via receiver)
        delete i;
        delete c;
    }

    public func makeMulti() {
        // Multi-level: Tower.Mid.Leaf where Leaf accesses both Mid and Tower fields.
        let t = new Tower();
        let m = t.new Tower.Mid();
        let leaf = m.new Tower.Mid.Leaf();
        p(leaf.sum());                              // 3 + 20 + 100 = 123
        delete leaf;
        delete m;
        delete t;
    }

    public func interfaceDispatch() {
        // Interface dispatch through a Greeter-typed local.
        let speaker = new Speaker();
        Greeter g = speaker;
        p(g.greet());                               // "speaker"
        delete speaker;
    }

    public func defaultImpl() {
         // Default-impl dispatch: DefaultUser only overrides required(), but optional()
         // has a default body in HasDefault that returns 0.
         let user = new DefaultUser();
         HasDefault h = user;
         p(h.required());                            // 7
         p(h.optional());                            // 0 (default impl)
         delete user;
    }

    public func loopTests() {
        // for-loop with postfix increment; prints 0, 1, 2.
        for (i32 i = 0; i < 3; i++) {
            p(i);
        }

        // while-loop with break: counts to 5 then breaks; prints 5.
        i32 j = 0;
        while (j < 100) {
            if (j == 5) {
                break;
            }
            j = j + 1;
        }
        p(j);

        // do-while loop runs body once before checking; prints 3 (1+1+1).
        i32 k = 0;
        do {
            k = k + 1;
        } while (k < 3);
        p(k);

        // prefix decrement; prints 2.
        i32 m = 3;
        --m;
        p(m);

        // continue: skip the iteration when n == 1; sum the rest. 0+2+3+4 = 9.
        i32 sum = 0;
        for (i32 n = 0; n < 5; n++) {
            if (n == 1) {
                continue;
            }
            sum = sum + n;
        }
        p(sum);
    }

    public func nullTests() {
        // Class nullable: `T?` is a pointer that may be null. The literal `null` only
        // binds to nullable targets.
        Speaker? optS = null;
        if (optS == null) {
            p("optS is null");
        }

        // ?? on a null left hand side picks the right hand fallback.
        let chosenA = optS ?? new Speaker();
        p(chosenA.greet());                     // "speaker"
        delete chosenA;

        // ?? on a non-null left hand side returns it (right is the dead branch).
        let realS = new Speaker();
        Speaker? present = realS;
        let chosenB = present ?? new Speaker();
        p(chosenB.greet());                     // "speaker"
        delete realS;
    }

    public func inheritanceTests() {
        // Upcast: Dog → Animal is implicit because Dog extends Animal.
        let dog = new Dog();
        Animal a = dog;

        // `is` walks the parent chain — Dog's vtable matches both Dog and Animal.
        if (a is Dog) {
            p("a is Dog");
        }
        if (a is Animal) {
            p("a is Animal");
        }

        // `as` downcast — chain-walk finds Dog at the head, returns the receiver.
        let back = a as Dog;
        p(back.bark());                     // "woof"
        delete dog;

        // A bare Animal is NOT a Dog — the chain walk reaches null without finding Dog.
        let alone = new Animal();
        Dog? optDog = alone as? Dog;
        if (optDog == null) {
            p("alone not a Dog");
        }
        delete alone;
    }

    public func castTests() {
        // Class → interface upcast. The runtime pointer is unchanged; only the static
        // type changes.
        let speaker = new Speaker();
        Greeter g = speaker;

        // `is` runtime kind check via vtable comparison.
        if (g is Speaker) {
            p("g is Speaker");
        }

        // `as` downcast — vtable matches, returns the receiver.
        let back = g as Speaker;
        p(back.greet());                         // "speaker"

        // `as?` downcast — when it matches, returns the receiver as a nullable.
        Speaker? maybeBack = g as? Speaker;
        let unwrapped = maybeBack ?? new Speaker();
        p(unwrapped.greet());                    // "speaker"

        delete speaker;

        // `as?` to a sibling implementer — at runtime the vtable doesn't match, so the
        // cast returns null. ?? then picks the fallback path.
        let whisperer = new Whisperer();
        Greeter g2 = whisperer;
        Speaker? mismatched = g2 as? Speaker;
        let fallbackS = mismatched ?? new Speaker();
        p(fallbackS.greet());                    // "speaker" (from the fallback)
        delete whisperer;
        delete fallbackS;
    }

    public class PrintName (string& name) {

        private HelloPrinter printer;

        public PrintName {
            printer = new HelloPrinter(name);
        }

        public ~PrintName() {
            delete printer;
        }

        public func print() {
            printer.print();
        }

    }

}
