module hello.world;

import cloth.io.Out::{ println };

public class (string[] args) {

    public Main {
        println(hello() + " " + world());

        i32 x = 5;
        x = 100;
        println(x);
    }

    public ~Main() {
    }

    public func hello(): string {
        return "Hello";
    }

    public func world(): string {
        return "World";
    }
}
