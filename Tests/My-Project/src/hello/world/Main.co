module hello.world;

import cloth.io.Out::{ println };

public class (string[] args) {

    public Main {
        sayHello();
    }

    public ~Main() {
    }

    public func sayHello(): void {
        string hello = "Hello, World!";

        //println(hello + "I am Cloth!");
        println();

        let small = 5;
        let big = 100000;
        let huge = 5000000000;
        let pi = 3.14;
        let flag = true;

        println(small);
        println(big);
        println(huge);
        println(pi);
        println(flag);

        println(5 + 5);
    }
}
