module hello.world;

import cloth.io.Out::{ println as p };
import hello.foo.Foo;

public class (string[] args) {

    private i32 x = 10;
    private Foo foo;

    public Main {
        let printer = new HelloPrinter("Wylan");
        printer.print();
        delete printer;

        let a = new Foo(7);
        p(a.get());
        delete a;

        let lhs = new Foo(11);
        let rhs = lhs;
        delete rhs;

        let acc = new Foo(1);
        let donor = new Foo(99);
        p(acc.consume(donor));
        delete acc;

        let core = new Foo(42);
        this.foo = core;
    }

    public ~Main() {
    }

    public func hello(): string {
        return "Hello";
    }

    public func world(): string {
        return "World";
    }

}
