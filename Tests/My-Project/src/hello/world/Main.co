module hello.world;

import cloth.io.Out::{ println as p };
import hello.foo.Foo;

public class (string[] args) {

    public Main {
        /*let mark = People.MARK;
        p(mark.getAverage());
        p(mark.getAge());
        p(mark.getName());
        p(mark.getOrdinal());
        p(mark.name());

        let james = People.JAMES;
        p(james.getName());
        p(james.getOrdinal());

        let mary = People.MARY;
        p(mary.getAge());
        p(mary.getOrdinal());

        // Bare-list enum: no constructor signature, only built-in ordinal + name.
        let c = Color.GREEN;
        p(c.getOrdinal());
        p(c.name());

        // valueOf(string): lookup-by-name. Returns the matching variant; null when none.
        let found = People.valueOf("JAMES") ?? People.MARK;
        p(found.getName());

        let missing = People.valueOf("NOBODY") ?? People.MARK;
        p(missing.getName());        // "Mark" — fallback when no match

        switch (mark) {
            case People.MARK:  p("hi Mark");
            case People.JAMES: p("hi James");
            case People.MARY:  p("hi Mary");
        }

        switch (james) {
            case People.MARK:  p("not james");
            case People.JAMES: p("yes james");
            case People.MARY:  p("not james");
        }

        // default arm — missing MARY but covered by default.
        switch (mary) {
            case People.MARK:  p("from mark");
            default:           p("default arm");
        }

        // Array literals + indexing + length.
        let nums = [10, 20, 30];
        p(nums[0]);
        p(nums[1]);
        p(nums[2]);
        p(nums::LENGTH);

        // for-in iteration over an array.
        for (i8 n in nums) {
            p(n);
        }

        // Heap-allocated array via `new T[n]` — size known only at runtime.
        let dynSize = 5;
        let zeros = new i32[dynSize];
        p(zeros::LENGTH);    // 5
        p(zeros[0]);         // 0 (calloc-zero-initialized)
        p(zeros[4]);         // 0

        // Enum `values()` + iteration.
        let allPeople = People.values();
        p(allPeople::LENGTH);     // 3
        for (People person in allPeople) {
            p(person.name());      // MARK, JAMES, MARY
        }

        p(People.values()[0].name()); // MARK
        p(People.values()::LENGTH); // 3

        string[] a = [];
        p(a::LENGTH); // 0

        // delete on a primitive-element array — frees the data buffer.
        let toFree = new i32[8];
        delete toFree;
        p("freed");

        // Array slot assignment.
        let buf = new i32[3];
        buf[0] = 10;
        buf[1] = 20;
        buf[2] = 30;
        p(buf[0]);
        p(buf[1]);
        p(buf[2]);
        buf[2] += 5;
        p(buf[2]);
        delete buf;

        // Element widening: literals (i8 each) widen to declared i32[].
        i32[] wide = [100, 200, 300];
        p(wide[0]);
        p(wide[1]);
        p(wide[2]);
        delete wide;

        // Same with f64[] — int literals lossless to f64.
        f64[] flt = [1, 2, 3];
        p(flt[0]);
        delete flt;

        // Sub-slicing: arr[lo..hi] returns a view over the same backing buffer.
        let big = [10, 20, 30, 40, 50];
        let mid = big[1..4];
        p(mid::LENGTH);   // 3
        p(mid[0]);        // 20
        p(mid[2]);        // 40
        delete big;

        // 2D allocation: new T[a][b].
        let grid = new i32[3][4];
        p(grid::LENGTH);          // 3 — outer rows
        p(grid[0]::LENGTH);       // 4 — inner cols
        grid[1][2] = 42;
        p(grid[1][2]);            // 42
        p(grid[0][0]);            // 0  — zero-initialized*/
        int[][] arrays = [[ 1, 2 ], [ 3, 4 ]];
        for (int i = 0; i < 2; i++) {
            for (int j = 0; j < 2; j++) {
                p(arrays[i][j]);
            }
        }

        // Ternary: same-type branches.
        let pick = true ? 7 : 9;
        p(pick);                          // 7

        // Ternary: width-mismatched branches widen to the wider type.
        i32 wide = false ? 5 : 1000;
        p(wide);                          // 1000

        // Ternary: int / float branches widen to float.
        f64 mix = true ? 1 : 2.5;
        p(mix);                           // 1.0

        // Ternary inside an expression chain.
        for (int k = 0; k < 3; k++) {
            p(k % 2 == 0 ? "even" : "odd");
        }

        // Switch widening: subject is i32, patterns are i8 literals.
        i32 sv = 1000;
        switch (sv) {
            case 5:    p("small");
            case 1000: p("hit");
            default:   p("miss");
        }

        // Static field widening: literal `7` (i8) widens to i32 in WidenStatic.SLOT.
        p(WidenStatic.SLOT);

        // Instance field widening: literal `9` (i8) widens to i32 in WidenInstance.value.
        let wi = new WidenInstance();
        p(wi.value);
        delete wi;

        // Virtual call arg widening: i8 literal `5` passed to i32 formal through interface dispatch.
        let wa = new WidenAcceptor();
        Widener w = wa;
        w.accept(5);     // prints 5 — arg widened to i32 before the indirect call
        delete wa;

        // `is Iface` / `as Iface` runtime kind checks via per-class implements bitmap.
        let ps = new PoliteSpeaker();
        let sp = new Speaker();
        Greeter g1 = ps;
        Greeter g2 = sp;

        p(g1 is Polite);           // true  — PoliteSpeaker implements Polite (extends Greeter)
        p(g1 is Greeter);          // true
        p(g2 is Polite);           // false — Speaker only implements Greeter
        p(g2 is Greeter);          // true

        let pol = g1 as Polite;    // unsafe downcast — succeeds
        p(pol.farewell());         // "goodbye"

        Polite? polMaybe = g2 as? Polite;
        p(polMaybe == null);       // true — Speaker is not a Polite

        delete ps;
        delete sp;
    }

    public ~Main() {
    }

}
