module hello.world;

import cloth.io.Out::{ println };

public class (string[] args) {

    private i32 x = 10;

    public Main {
        println(hello() + " " + world());
        println(this.x);
    }

    public ~Main() {
    }

    public func hello(): string {
        return "Hello";
    }

    public func world(): string {
        return "World";
    }
}
