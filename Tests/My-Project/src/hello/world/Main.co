module hello.world;

import cloth.io.Out::{ println as p };
import hello.foo.Foo;

public class (string[] args) {

    private i32 x = 10;
    private Foo foo;

    public Main {
        let printer = new HelloPrinter();
        printer.printHelloWorld();
        delete printer;

        foo = new Foo();
        p(foo.get());
        delete foo;
    }

    public ~Main() {
        p("Goodbye");
    }

    public func hello(): string {
        return "Hello";
    }

    public func world(): string {
        return "World";
    }

}
