module my.project;

import cloth.io.IO::{ println };

#Trait Final
public class () extends MyObject is Serializable {

    private const string? hello = "Hello World!" {
        public getter as get();
    };

    public Main {
        println(get());

        guard canThrow1() -> e {
            println(e);
        };

        let exception = guard canThrow();

        if (exception is NPE) {
            println("Null Pointer Exception");
        }

        guard {
            canThrow1();
            canThrow();
        } -> e {
            println(e);
        };
    }

    public Main(string name) {
        println("Hello " + name);
        Main();
    }

    public ~Main() {
    }

    private func canThrow() :> string? maybe NPE {
        return null;
    }

    private func canThrow1() :> string? maybe NPE {
        return null;
    }

    private func messageLength() :> int {
        return hello::LENGTH;
    }

}